{
  "entities": {
    "ExpressionOfInterest": {
      "title": "Expression of Interest",
      "description": "An expression of interest from an institution.",
      "type": "object",
      "properties": {
        "institutionName": { "type": "string", "maxLength": 200 },
        "institutionType": { "type": "string", "maxLength": 100 },
        "city": { "type": "string", "maxLength": 100 },
        "country": { "type": "string", "maxLength": 100 },
        "contactPerson": { "type": "string", "maxLength": 150 },
        "role": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "format": "email", "maxLength": 150 },
        "phone": { "type": "string", "maxLength": 50 },
        "currentEnrollment": { "type": "string", "maxLength": 100 },
        "programsOffered": {
          "type": "array",
          "items": { "type": "string", "maxLength": 100 },
          "maxItems": 20
        },
        "objectives": {
          "type": "array",
          "items": { "type": "string", "maxLength": 100 },
          "maxItems": 20
        },
        "interestedPrograms": {
          "type": "array",
          "items": { "type": "string", "maxLength": 100 },
          "maxItems": 20
        },
        "currentInternationalTies": { "type": "string", "maxLength": 10 },
        "toolsUsed": { "type": "string", "maxLength": 500 },
        "budgetCommitment": { "type": "string", "maxLength": 100 },
        "additionalInfo": { "type": "string", "maxLength": 2000 },
        "createdAt": { "type": "number" }
      },
      "required": [
        "institutionName",
        "institutionType",
        "city",
        "country",
        "contactPerson",
        "role",
        "email",
        "phone",
        "createdAt"
      ]
    },
    "ForeignExpressionOfInterest": {
      "title": "Foreign Expression of Interest",
      "description": "An expression of interest from a foreign institution.",
      "type": "object",
      "properties": {
        "institutionName": { "type": "string", "maxLength": 200 },
        "website": { "type": "string", "maxLength": 200 },
        "accreditationStatus": { "type": "string", "maxLength": 1000 },
        "primaryObjectives": { "type": "string", "maxLength": 2000 },
        "fieldsOfStudy": { "type": "string", "maxLength": 1000 },
        "deliveryMode": { "type": "string", "maxLength": 100 },
        "tuitionRange": { "type": "string", "maxLength": 200 },
        "revenueSharing": { "type": "string", "maxLength": 100 },
        "localizedPricing": { "type": "string", "maxLength": 100 },
        "cobrandedPrograms": { "type": "string", "maxLength": 100 },
        "maxStudentCapacity": { "type": "string", "maxLength": 100 },
        "experienceInternational": { "type": "string", "maxLength": 100 },
        "facultyAvailability": { "type": "string", "maxLength": 100 },
        "remoteAssessments": { "type": "string", "maxLength": 100 },
        "partnerExpectations": { "type": "string", "maxLength": 2000 },
        "involvementLevel": { "type": "string", "maxLength": 100 },
        "timeline": { "type": "string", "maxLength": 100 },
        "decisionMaker": { "type": "string", "maxLength": 200 },
        "contactName": { "type": "string", "maxLength": 150 },
        "contactTitle": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "format": "email", "maxLength": 150 },
        "phone": { "type": "string", "maxLength": 50 },
        "createdAt": { "type": "number" }
      },
      "required": [
        "institutionName",
        "website",
        "accreditationStatus",
        "primaryObjectives",
        "fieldsOfStudy",
        "deliveryMode",
        "tuitionRange",
        "revenueSharing",
        "localizedPricing",
        "cobrandedPrograms",
        "maxStudentCapacity",
        "experienceInternational",
        "facultyAvailability",
        "remoteAssessments",
        "partnerExpectations",
        "involvementLevel",
        "timeline",
        "decisionMaker",
        "contactName",
        "contactTitle",
        "email",
        "phone",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/eois/{eoiId}": {
      "schema": { "$ref": "#/entities/ExpressionOfInterest" },
      "description": "Stores all the submitted expression of interest forms."
    },
    "/foreign_eois/{eoiId}": {
      "schema": { "$ref": "#/entities/ForeignExpressionOfInterest" },
      "description": "Stores foreign expression of interest forms."
    }
  }
}
